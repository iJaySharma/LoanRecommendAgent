server:
  port: 8080
spring:
  application:
    name: car-loan-recommendation
  datasource:
    url: jdbc:h2:mem:recommend;DB_CLOSE_DELAY=-1;MODE=PostgreSQL
    driverClassName: org.h2.Driver
    username: sa
    password:
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: true
  h2:
    console:
      enabled: true
      path: /h2-console
  sql:
    init:
      mode: always
      data-locations: classpath:data.sql
  llm:
	  provider: google
	  api-key: ${LLM_API_KEY:}
	  base-url: https://generativelanguage.googleapis.com/v1beta/openai/
	  model: gemini-2.0-flash
logging:
  level:
    com.example.recommend: DEBUG